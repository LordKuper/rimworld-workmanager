{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git mv:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(gh repo:*)",
      "Bash(likec4:*)",
      "Bash(designmd:*)",
      "Bash(npx @google/design.md:*)",
      "Bash(codex:*)",
      "Bash(codex.exe:*)",
      "Bash(npm install @google/design.md)",
      "Bash(npm install @google/design.md:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-start.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/stop.js"
          }
        ]
      }
    ]
  }
}
